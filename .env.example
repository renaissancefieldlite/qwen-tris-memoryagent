# Qwen Cloud / Alibaba Cloud Model Studio
# Copy to .env.local and fill with your real key locally. Do not commit .env.local.
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Local fallback routes
TRINI_QWEN_MODEL=qwen2.5:3b
TRINI_NEMOTRON_MODEL=hf.co/nvidia/NVIDIA-Nemotron-3-Nano-4B-GGUF:Q4_K_M
TRINI_OLLAMA_BASE=http://127.0.0.1:11434

# Local persistence defaults for the demo backend
TRINI_RECALL_DB_PATH=/tmp/trini_recall_chat_memory.sqlite3
TRINI_RECALL_JSONL_PATH=/tmp/trini_recall_chat_memory.jsonl
